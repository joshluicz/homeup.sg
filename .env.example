NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Rent intake — signed form token + rate limiting (server-only, min 16 chars)
INTAKE_FORM_SECRET=generate-a-long-random-string-here

# Rent intake thank-you WhatsApp CTA (digits only, e.g. 6580877015)
NEXT_PUBLIC_CONTACT_WHATSAPP=6580877015

# Optional override for article pipeline Claude model (default: claude-sonnet-5)
# HOMEUP_LLM_MODEL=claude-sonnet-5
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google Analytics 4 — site tracking (public) + admin dashboard read-back (server-only)
# Set these on whatever host runs the Next.js app (e.g. Railway Variables, or .env.local locally).
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-FYWLSSTYJ6
# GA_PROPERTY_ID=123456789
# GA_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Google Search Console — used for article search metrics, URL Inspection, and indexing monitor.
# If omitted, GSC_SERVICE_ACCOUNT_JSON falls back to GA_SERVICE_ACCOUNT_JSON and GSC_SITE_URL
# falls back to sc-domain:homeup.sg.
# GSC_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GSC_SITE_URL=sc-domain:homeup.sg

# DNS-AID publishing (scripts/publish-dns-aid.mjs) — Cloudflare token needs Zone.DNS Edit + Zone.DNSSEC
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_DOMAIN=homeup.sg

# Google Maps — enable Maps JavaScript API + Maps Embed API on the same key
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=
