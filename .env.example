NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# One-time DB setup for agent profile videos (scripts/setup-agent-profile-videos.mjs)
# Supabase Dashboard → Project Settings → Database → Database password
SUPABASE_DB_PASSWORD=

ANTHROPIC_API_KEY=your-anthropic-api-key

# DNS-AID publishing (scripts/publish-dns-aid.mjs) — Cloudflare token needs Zone.DNS Edit + Zone.DNSSEC
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_DOMAIN=homeup.sg
