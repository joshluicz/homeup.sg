NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Rent intake — signed form token + rate limiting (server-only, min 16 chars)
INTAKE_FORM_SECRET=generate-a-long-random-string-here

# Rent intake thank-you WhatsApp CTA (digits only, e.g. 6580877015)
NEXT_PUBLIC_CONTACT_WHATSAPP=6580877015

ANTHROPIC_API_KEY=your-anthropic-api-key

# Google Analytics 4 — site tracking (public) + admin dashboard read-back (server-only)
# Set these on whatever host runs the Next.js app (e.g. Railway Variables, or .env.local locally).
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-FYWLSSTYJ6
# GA_PROPERTY_ID=123456789
# GA_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# DNS-AID publishing (scripts/publish-dns-aid.mjs) — Cloudflare token needs Zone.DNS Edit + Zone.DNSSEC
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_DOMAIN=homeup.sg
